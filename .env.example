# PR AI — environment variables
# Copy to `.env.local` and fill in values before running Phase 1.

# -----------------------------------------------------------------------------
# Auth.js (Phase 1)
# Generate with: openssl rand -base64 32
# -----------------------------------------------------------------------------
AUTH_SECRET=

# GitHub OAuth App — https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# -----------------------------------------------------------------------------
# Database (Phase 1)
# PostgreSQL via Supabase, Neon, or local Docker
# -----------------------------------------------------------------------------
DATABASE_URL=

# -----------------------------------------------------------------------------
# Encryption (Phase 1)
# 32-byte key, base64-encoded — openssl rand -base64 32
# -----------------------------------------------------------------------------
TOKEN_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# AI providers (Phase 3+ — platform keys or user BYOK in Phase 6)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Default models for LLM Council (optional overrides)
AGENT1_MODEL=
AGENT2_MODEL=

# -----------------------------------------------------------------------------
# Background jobs (Phase 3 — pick Inngest or QStash)
# -----------------------------------------------------------------------------
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=
# Run Inngest dev server alongside Next.js: npx inngest-cli@latest dev
# QSTASH_TOKEN=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
